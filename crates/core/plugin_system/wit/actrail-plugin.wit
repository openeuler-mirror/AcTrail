package actrail:plugin@0.2.0;

interface types {
  enum observation-event-family {
    semantic-action,
    semantic-action-link,
    diagnostic,
    trace-lifecycle,
    resource-metric,
    payload-metadata,
  }

  enum control-subject {
    file-access,
    command-execution,
    network-action,
  }

  enum control-verdict {
    allow,
    deny,
  }

  enum decision-scope {
    once,
    reusable,
  }

  enum payload-read-status {
    ok,
    denied,
    not-found,
    truncated,
  }

  enum config-read-status {
    ok,
    not-configured,
    too-large,
  }

  enum file-change-kind {
    created,
    modified,
    deleted,
    unknown,
  }

  enum path-observation-state {
    complete,
    unavailable,
  }

  enum trace-lifecycle-state {
    starting,
    active,
    draining,
    completed,
    exited,
    failed,
  }

  enum trace-file-state-status {
    exists,
    not-found,
    inaccessible,
    unavailable,
  }

  record payload-ref {
    id: string,
    trace-id: string,
  }

  record payload-chunk {
    status: payload-read-status,
    bytes: list<u8>,
    offset: u64,
    next-offset: option<u64>,
    total-size-hint: option<u64>,
    truncated: bool,
    redaction-applied: bool,
  }

  record config-chunk {
    status: config-read-status,
    bytes: list<u8>,
    offset: u64,
    next-offset: option<u64>,
    total-size-hint: option<u64>,
    truncated: bool,
  }

  record trace-context {
    working-directory: option<string>,
    alert-token: option<list<u8>>,
  }

  record file-change-record {
    operation: string,
    change-kind: file-change-kind,
    successful: bool,
    path: option<string>,
    path-state: path-observation-state,
  }

  record semantic-action-record {
    action-id: string,
    kind: string,
    status: string,
    completeness: string,
    file-change: option<file-change-record>,
  }

  record observation-batch {
    batch-id: string,
    trace-id: string,
    trace-sequence: u64,
    lifecycle-transition: option<trace-lifecycle-state>,
    families: list<observation-event-family>,
    semantic-actions: list<semantic-action-record>,
    payload-refs: list<payload-ref>,
  }

  record observation-report {
    observed-records: u64,
    dropped-records: u64,
  }

  record actor-process-identity {
    pid: u32,
    task-id: option<u32>,
    generation: u64,
    namespace: option<string>,
  }

  record decision-request {
    decision-id: string,
    trace-id: string,
    task-id: option<string>,
    subject: control-subject,
    actor-process-identity: actor-process-identity,
    operation: string,
    target-summary: string,
    context-ref: option<string>,
  }

  record decision-response {
    verdict: control-verdict,
    scope: decision-scope,
    reason-code: option<string>,
    reason-message: option<string>,
  }

  record decision-summary {
    subject: control-subject,
    operation: string,
    target-summary: string,
    decision-id: string,
    trace-id: string,
    actor-process-identity: string,
  }

  record file-policy-view {
    rule-id: string,
    decision: string,
    operation: string,
    path: string,
    plugin-instance: option<string>,
    timeout-ms: option<u64>,
    concurrency-limit: option<u32>,
    fallback: option<string>,
  }

  enum file-policy-decision {
    default,
    allow,
    deny,
    gray,
  }

  enum file-policy-operation {
    any,
    open,
    mkdir,
    rmdir,
  }

  enum file-policy-patch-op {
    upsert,
    delete,
    enable,
    disable,
  }

  enum file-policy-apply-mode {
    partial,
    aon,
  }

  enum file-policy-apply-status {
    accepted,
    rejected,
  }

  record file-policy-rule-draft {
    rule-id: option<string>,
    decision: file-policy-decision,
    operation: file-policy-operation,
    path: string,
    gray-target: option<u64>,
    priority: s32,
  }

  record file-policy-patch-item {
    op: file-policy-patch-op,
    rule-id: option<string>,
    rule: option<file-policy-rule-draft>,
  }

  record file-policy-apply-request {
    base-revision: u64,
    mutation-id: string,
    reason: option<string>,
    correlation-id: option<string>,
    apply-mode: file-policy-apply-mode,
    items: list<file-policy-patch-item>,
  }

  record file-policy-list-filter {
    decision: option<file-policy-decision>,
    path-prefix: option<string>,
    operation: option<file-policy-operation>,
  }

  record file-policy-rule-view {
    rule-id: string,
    owner-instance-id: string,
    decision: file-policy-decision,
    operation: file-policy-operation,
    path: string,
    gray-target: option<u64>,
    priority: s32,
    enabled: bool,
    updated-sequence: u64,
  }

  record file-policy-list-result {
    rules: list<file-policy-rule-view>,
    next-cursor: option<string>,
    source-revision: u64,
  }

  record file-policy-match-dry-run-request {
    path: string,
    operation: file-policy-operation,
  }

  record file-policy-match-dry-run-result {
    matched: bool,
    decision: file-policy-decision,
    rule-id: option<string>,
    operation: file-policy-operation,
    canonical-path: string,
    source-revision: u64,
  }

  record plugin-command-request {
    argv: list<string>,
  }

  record plugin-command-result {
    exit-code: s32,
    stdout: string,
    stderr: string,
  }

  record post-trace-task {
    trace-id: string,
  }

  record trace-analysis-context {
    terminal-at: u64,
    working-directory: option<string>,
  }

  record trace-action-page {
    actions: list<semantic-action-record>,
    next-offset: option<u64>,
  }

  record trace-file-state {
    status: trace-file-state-status,
    checked-at: u64,
    file-kind: option<string>,
  }

  record alert-draft {
    definition-key: string,
    payload-json: string,
  }

  record alert-write-request {
    trace-id: string,
    alert-token: list<u8>,
    draft: alert-draft,
  }

  record file-policy-apply-error {
    item-index: u32,
    code: string,
    message: string,
  }

  record file-policy-apply-result {
    status: file-policy-apply-status,
    new-revision: u64,
    applied-count: u32,
    rejected-count: u32,
    errors: list<file-policy-apply-error>,
  }
}

interface host {
  use types.{payload-ref, payload-chunk, config-chunk, decision-summary, file-policy-view, file-policy-apply-request, file-policy-apply-result, file-policy-list-filter, file-policy-list-result, file-policy-match-dry-run-request, file-policy-match-dry-run-result};

  read-config: func(offset: u64, max-bytes: u64) -> config-chunk;
  read-payload: func(ref: payload-ref, offset: u64, max-bytes: u64) -> payload-chunk;
  query-context: func(context-ref: string, query: string) -> result<decision-summary, string>;
  file-access-current-match-get: func(context-ref: string, query: string) -> result<file-policy-view, string>;
  file-policy-rules-version-get: func() -> result<u64, string>;
  file-policy-rules-list: func(filter: file-policy-list-filter, cursor: option<string>, limit: u32) -> result<file-policy-list-result, string>;
  file-policy-rules-match-dry-run: func(request: file-policy-match-dry-run-request) -> result<file-policy-match-dry-run-result, string>;
  file-policy-rules-validate: func(request: file-policy-apply-request) -> result<file-policy-apply-result, string>;
  file-policy-rules-apply: func(request: file-policy-apply-request) -> result<file-policy-apply-result, string>;
  env-read: func(name: string, max-bytes: u64) -> result<string, string>;
}

interface observation-context-read {
  use types.{trace-context};

  trace-context-get: func() -> result<trace-context, string>;
}

interface trace-analysis-read {
  use types.{trace-analysis-context, trace-action-page};

  context-get: func() -> result<trace-analysis-context, string>;
  semantic-actions-list: func(offset: option<u64>, limit: u32) -> result<trace-action-page, string>;
}

interface trace-file-state-read {
  use types.{trace-file-state};

  get: func(action-id: string) -> result<trace-file-state, string>;
}

interface alert-write {
  use types.{alert-write-request};

  submit: func(request: alert-write-request) -> result<_, string>;
}

interface observation-consumer {
  use types.{observation-batch, observation-report};

  consume: func(batch: observation-batch) -> result<observation-report, string>;
}

interface control-decider {
  use types.{decision-request, decision-response};

  decide: func(request: decision-request) -> result<decision-response, string>;
}

interface management-command {
  use types.{plugin-command-request, plugin-command-result};

  handle-command: func(request: plugin-command-request) -> result<plugin-command-result, string>;
}

interface runtime-config {
  get: func() -> result<string, string>;
  validate: func(config-json: string) -> result<list<string>, string>;
  submit: func(config-json: string) -> result<_, string>;
}

interface post-trace-analyzer {
  use types.{post-trace-task};

  analyze: func(task: post-trace-task) -> result<_, string>;
}

world observation-plugin {
  import host;
  import observation-context-read;
  import alert-write;
  export observation-consumer;
}

world post-trace-observation-plugin {
  import host;
  import observation-context-read;
  import trace-analysis-read;
  import trace-file-state-read;
  import alert-write;
  export observation-consumer;
  export post-trace-analyzer;
}

world control-plugin {
  import host;
  export control-decider;
}

world managed-control-plugin {
  import host;
  export control-decider;
  export management-command;
  export runtime-config;
}

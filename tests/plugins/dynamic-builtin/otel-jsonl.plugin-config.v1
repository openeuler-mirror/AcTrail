{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["path", "overwrite_enabled", "queue_capacity", "flush_every_spans"],
  "additionalProperties": false,
  "properties": {
    "path": {
      "type": "string",
      "minLength": 1
    },
    "overwrite_enabled": {
      "type": "boolean"
    },
    "queue_capacity": {
      "type": "integer",
      "minimum": 1
    },
    "flush_every_spans": {
      "type": "integer",
      "minimum": 1
    }
  }
}
